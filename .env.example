# ── APLICACIÓN ───────────────────────────────────
APP_NAME="Sistema CV"
APP_VERSION="1.0.0"
ENVIRONMENT="production"         # production | development

# ── SERVIDOR ─────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── SEGURIDAD ─────────────────────────────────────
# Generá una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_segura_antes_de_usar
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas

# ── BASE DE DATOS ─────────────────────────────────
DATABASE_URL=sqlite:///./database/sistema_cv.db

# ── IA — VERSIÓN 2 (OLLAMA LOCAL) ────────────────
IA_PROVIDER=ollama               # ollama | openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── IA — VERSIÓN 1 (OPENAI) — solo si IA_PROVIDER=openai ──
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── STORAGE ──────────────────────────────────────
STORAGE_CVS_PATH=storage/cvs
STORAGE_EXPORTS_PATH=storage/exports
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf

# ── ADMIN POR DEFECTO (seed inicial) ─────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2025!       # Cambiar en el primer inicio
